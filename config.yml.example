# steven-reviewer ingestion config.
#
# Copy to config.yml and edit. config.yml is gitignored.
#
# Mirrors agent/vault/projects/steven-reviewer/config.yml in my-agent for
# the repo list. Keep them in sync.

# Path to the PAT file (chmod 600). $HOME is expanded.
token_path: ~/.config/steven-reviewer/gh-token

# Path to the local sqlite database.
db_path: ./ingest.db

# Path to the my-agent checkout (used by the walk-through to write into
# the vault). $HOME is expanded.
my_agent_path: ~/agent

# Author filter applied to all repos by default. Override per-repo below.
default_author: Emyrk

repos:
  - name: coder/coder
    tag: work
  - name: Emyrk/imperium
    tag: personal
  - name: Emyrk/my-agent
    tag: personal
  - name: Emyrk/chronicle
    tag: personal
